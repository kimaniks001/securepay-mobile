# SecurePay Mobile — local environment (do not commit .env files)
# Default mode is mock. Staging requires an explicit gateway base URL.
# Production API remains disabled in Mobile Phase 5.

EXPO_PUBLIC_SECUREPAY_API_MODE=mock
EXPO_PUBLIC_SECUREPAY_API_BASE_URL=
EXPO_PUBLIC_SECUREPAY_ENABLE_API_WRITES=false
EXPO_PUBLIC_SECUREPAY_ALLOW_PRODUCTION_API=false

# --- Staging smoke test (local developer machine only — NEVER commit) ---
# Run: node scripts/mobile-staging-readonly-smoke.mjs
# Requires:
#   EXPO_PUBLIC_SECUREPAY_API_MODE=staging
#   EXPO_PUBLIC_SECUREPAY_API_BASE_URL=https://your-approved-staging-gateway.example
# Optional:
#   SECUREPAY_SMOKE_ACCESS_TOKEN=your-local-bearer-token
#   SECUREPAY_SMOKE_TEST_SLUG=optional-securelink-slug
#
# Rules:
# - Staging URL must be developer-provided locally
# - Staging credentials must never be committed
# - Never provide staging secrets to Cloud Agents
# - Production securepay.ke URLs are blocked by default
# - Smoke test writes report to logs/ (gitignored)

# Staging app example (approved staging gateway URL only):
# EXPO_PUBLIC_SECUREPAY_API_MODE=staging
# EXPO_PUBLIC_SECUREPAY_API_BASE_URL=https://staging-api.example.securepay.test
