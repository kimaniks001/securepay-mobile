# SecurePay Mobile — local environment (do not commit .env files)
# Default mode is mock. Staging requires an explicit gateway base URL.
# Production API remains disabled in Mobile Phase 4.

EXPO_PUBLIC_SECUREPAY_API_MODE=mock
EXPO_PUBLIC_SECUREPAY_API_BASE_URL=
EXPO_PUBLIC_SECUREPAY_ENABLE_API_WRITES=false
EXPO_PUBLIC_SECUREPAY_ALLOW_PRODUCTION_API=false

# Staging example (use your approved staging gateway URL only):
# EXPO_PUBLIC_SECUREPAY_API_MODE=staging
# EXPO_PUBLIC_SECUREPAY_API_BASE_URL=https://staging-api.example.securepay.test
